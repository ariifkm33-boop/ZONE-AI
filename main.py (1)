        f"🔍 মোট টোকেন পাওয়া: {found_count}\n"
        f"✅ Active বট: {active_count}\n"
        f"❌ Inactive: {found_count - active_count}\n"
        f"⏱ সময়: {duration:.1f} সেকেন্ড\n\n"
        f"নিচে বিস্তারিত 👇"
    )
    
    bot.send_message(uid, report)
    
    # Active বটগুলো দেখাও
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT * FROM found_tokens WHERE is_active=1 ORDER BY found_date DESC LIMIT 20")
    active_bots = c.fetchall()
    conn.close()
    
    if active_bots:
        kb = types.InlineKeyboardMarkup(row_width=1)
        for b in active_bots[:10]:
            btn_text = f"✅ @{b['bot_username']} | {b['source']}"
