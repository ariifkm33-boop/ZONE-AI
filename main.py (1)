# স্ট্যাটাস
# =====================================
def show_stats(uid):
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM found_tokens")
    total = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM found_tokens WHERE is_active=1")
    active = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM scan_history")
    scans = c.fetchone()[0]
    
    c.execute("SELECT value FROM settings WHERE key='total_scans'")
    total_scans = c.fetchone()
    total_scans = total_scans[0] if total_scans else '0'
    
    c.execute("SELECT value FROM settings WHERE key='total_tokens_found'")
    total_found = c.fetchone()
    total_found = total_found[0] if total_found else '0'
    
    c.execute("SELECT value FROM settings WHERE key='last_scan'")
    last_scan = c.fetchone()
    last_scan = last_scan[0][:19] if last_scan and last_scan[0] else 'N/A'
    
    c.execute("SELECT source, COUNT(*) as cnt FROM found_tokens GROUP BY source ORDER BY cnt DESC")
    sources = c.fetchall()
    conn.close()
    
    txt = (
        f"📊 *স্ট্যাটাস রিপোর্ট*\n\n"
        f"🤖 মোট বট: {total}\n"
        f"✅ Active: {active}\n"
        f"❌ Inactive: {total - active}\n"
        f"🔍 মোট স্ক্যান: {total_scans}\n"
        f"🎯 মোট টোকেন ফাউন্ড: {total_found}\n"
        f"📅 শেষ স্ক্যান: {last_scan}\n\n"
        f"📡 *সোর্স ওয়াইজ:*\n"
    )
    
    for s in sources:
        txt += f"   • {s['source']}: {s['cnt']}টি\n"
    
    bot.send_message(uid, txt)

