# 📥 ফাইল থেকে টোকেন এক্সট্র্যাক্ট
# =====================================
def get_file_content(repo, file_path):
    """GitHub রিপো থেকে ফাইল কন্টেন্ট পড়ো"""
    try:
        url = f"https://raw.githubusercontent.com/{repo}/main/{file_path}"
        resp = requests.get(url, timeout=8)
        if resp.status_code == 200:
            return resp.text
        
        # Fallback: master branch
        url2 = f"https://raw.githubusercontent.com/{repo}/master/{file_path}"
        resp2 = requests.get(url2, timeout=8)
        if resp2.status_code == 200:
            return resp2.text
        
        return None
    except:
        return None

def extract_tokens(content):
    """কন্টেন্ট থেকে সব টোকেন বের করো"""
    tokens = []
    
    patterns = [
        # স্ট্যান্ডার্ড টেলিগ্রাম বট টোকেন
        r'(?:^|[^a-zA-Z0-9])(\d{8,10}:[A-Za-z0-9_-]{35,40})(?:$|[^a-zA-Z0-9_])',
        # কোটেশনে থাকা
        r'[''"`](\d{8,10}:[A-Za-z0-9_-]{35,40})[''"`]',
        # পরিবর্তনশীলে
        r'(?:BOT_TOKEN|TOKEN|API_TOKEN|TELEGRAM_TOKEN|BOT_TOKEN|bot_token|api_key|API_KEY)\s*[=:]\s*[''"`]?(\d{8,10}:[A-Za-z0-9_-]{35,40})',
        # env ফাইল
        r'(?:export\s+)?(?:BOT|TELEGRAM|API)_?(?:TOKEN|KEY)\s*[=:]\s*[''"`]?(\d{8,10}:[A-Za-z0-9_-]{35,40})',
    ]
    
    for pattern in patterns:
        matches = re.findall(pattern, content, re.IGNORECASE | re.MULTILINE)
        tokens.extend(matches)
    
    # ভ্যালিড টোকেন ফিল্টার
    valid_tokens = []
    for t in tokens:
        t = t.strip()
        if re.match(r'^\d{8,10}:[A-Za-z0-9_-]{35,40}$', t):
            valid_tokens.append(t)
    
    return list(set(valid_tokens))

# =====================================
# 🎯 গিটহাবে পাবলিক রিপো সার্চ (রেপোজিটরি সার্চ)
# =====================================
def search_repos_for_tokens(max_repos=30):
    """পাবলিক রিপোজিটরিগুলোতে টোকেন খোঁজো"""
    tokens_found = []
    
    # জনপ্রিয় কিওয়ার্ড
    keywords = [
        'telegram bot', 'telegram-bot', 'telegram_bot',
        'pyTelegramBotAPI', 'python-telegram-bot',
        'aiogram', 'telepot', 'python-telegram',
        'discord bot', 'discord-bot', 'discord_bot',
        'whatsapp bot', 'wa-bot',
    ]
    
    headers = {'Accept': 'application/vnd.github.v3+json'}
    
    for keyword in keywords[:5]:
        try:
            url = f"https://api.github.com/search/repositories?q={requests.utils.quote(keyword)}+language:python&sort=updated&per_page=20"
            resp = requests.get(url, headers=headers, timeout=10)
            
            if resp.status_code == 200:
                data = resp.json()
                for item in data.get('items', []):
                    repo = item['full_name']
                    repo_url = item['html_url']
                    
                    # রিপোর ফাইল লিস্ট
                    contents_url = f"https://api.github.com/repos/{repo}/contents"
                    contents_resp = requests.get(contents_url, headers=headers, timeout=8)
                    
                    if contents_resp.status_code == 200:
                        files = contents_resp.json()
                        for file in files:
                            if isinstance(file, dict) and file['type'] == 'file':
                                fname = file['name']
                                if any(fname.endswith(ext) for ext in ['.py', '.env', '.txt', '.json', '.yml', '.yaml', '.cfg', '.ini', '.conf', '.secret']):
                                    
                                    content = get_file_content(repo, fname)
                                    if content:
                                        tokens = extract_tokens(content)
                                        for token in tokens:
                                            tokens_found.append({
                                                'token': token,
                                                'repo': repo,
                                                'repo_url': repo_url,
                                                'file': fname
                                            })
                                            
                                            if len(tokens_found) >= max_repos:
                                                return tokens_found
            
            time.sleep(0.5)
            
        except:
            continue
    
    return tokens_found[:max_repos]

