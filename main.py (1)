@bot.message_handler(func=lambda m: True)
def handle(message):
    uid = message.from_user.id
    if uid not in ADMIN_IDS:
        bot.reply_to(message, "⛔ অননুমোদিত!")
        return
    
    text = message.text
    
    if text == "🔍 🔥 সার্চ শুরু করো":
        search_all_sources(uid)
    
    elif text == "🤖 ফাউন্ড বট":
        show_found_bots(uid)
    
    elif text == "✅ শুধু Active বট":
        show_active_bots(uid)
    
    elif text == "📊 স্ট্যাটাস":
        show_stats(uid)
    
    elif text == "📋 স্ক্যান হিস্টোরি":
        show_scan_history(uid)
    
    elif text == "🔄 রি-টেস্ট সব":
        retest_all(uid)

