def show_scan_history(uid):
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT * FROM scan_history ORDER BY id DESC LIMIT 15")
    scans = c.fetchall()
    conn.close()
    
    if not scans:
        bot.send_message(uid, "❌ কোনো স্ক্যান করা হয়নি!")
        return
    
    txt = "📋 *স্ক্যান ইতিহাস:*\n\n"
    for s in scans:
        txt += f"🔍 {s['source']}\n"
        txt += f"   স্ক্যান করা: {s['items_scanned']} | পাওয়া: {s['tokens_found']} | Active: {s['tokens_active']}\n"
        txt += f"   📅 {s['scan_date'][:19]} | ⏱ {s['duration_seconds']:.1f}s\n\n"
    
    bot.send_message(uid, txt)

