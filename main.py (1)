# 🎯 গিটল্যাব সার্চ
# =====================================
def search_gitlab(query='telegram bot token', max_results=20):
    """GitLab এ সার্চ করো"""
    results = []
    
    try:
        url = f"https://gitlab.com/api/v4/projects?search={requests.utils.quote(query)}&per_page=20&order_by=last_activity_at"
        resp = requests.get(url, timeout=10)
        
        if resp.status_code == 200:
            projects = resp.json()
            for project in projects:
                repo_name = project.get('path_with_namespace', '')
                repo_url = project.get('web_url', '')
                
                # ফাইলগুলো চেক
                files_url = f"https://gitlab.com/api/v4/projects/{project['id']}/repository/tree"
                files_resp = requests.get(files_url, timeout=8)
                
                if files_resp.status_code == 200:
                    files = files_resp.json()
                    for file in files:
                        fname = file.get('name', '')
                        if any(fname.endswith(ext) for ext in ['.py', '.env', '.txt', '.json', '.yml', '.yaml']):
                            # ফাইল কন্টেন্ট পড়ো
                            raw_url = f"https://gitlab.com/{repo_name}/-/raw/main/{fname}"
                            raw_resp = requests.get(raw_url, timeout=8)
                            
                            if raw_resp.status_code == 200:
                                tokens = extract_tokens(raw_resp.text)
                                for token in tokens:
                                    results.append({
                                        'token': token,
                                        'repo': repo_name,
                                        'repo_url': repo_url,
                                        'file': fname,
                                        'source': 'GitLab'
                                    })
                                    
                                    if len(results) >= max_results:
                                        return results
        
        time.sleep(0.3)
    except:
        pass
    
    return results[:max_results]

# =====================================
# 🎯 বিটবাকেট সার্চ
# =====================================
def search_bitbucket(query='telegram bot', max_results=10):
    """BitBucket এ সার্চ করো"""
    results = []
    
    try:
        url = f"https://api.bitbucket.org/2.0/repositories?q=name~%22{requests.utils.quote(query)}%22&pagelen=10"
        resp = requests.get(url, timeout=10)
        
        if resp.status_code == 200:
            data = resp.json()
            for repo in data.get('values', []):
                repo_name = repo.get('full_name', '')
                repo_url = repo.get('links', {}).get('html', {}).get('href', '')
                
                # ফাইলগুলো চেক
                src_url = f"https://api.bitbucket.org/2.0/repositories/{repo_name}/src/main"
                src_resp = requests.get(src_url, timeout=8)
                
                if src_resp.status_code == 200:
                    files = src_resp.json().get('values', [])
                    for file in files:
                        if file.get('type') == 'commit_file':
                            fname = file.get('path', '')
                            if any(fname.endswith(ext) for ext in ['.py', '.env', '.txt', '.json']):
                                raw_url = f"https://bitbucket.org/{repo_name}/raw/main/{fname}"
                                raw_resp = requests.get(raw_url, timeout=8)
                                
                                if raw_resp.status_code == 200:
                                    tokens = extract_tokens(raw_resp.text)
                                    for token in tokens:
                                        results.append({
                                            'token': token,
                                            'repo': repo_name,
                                            'repo_url': repo_url,
                                            'file': fname,
                                            'source': 'BitBucket'
                                        })
        
        time.sleep(0.3)
    except:
        pass
    
    return results[:max_results]

# =====================================
# 🎯 গিটLAB GIST সার্চ
# =====================================
def search_gists(query='telegram bot token', max_results=20):
    """GitHub Gist এ সার্চ করো"""
    results = []
    
    headers = {'Accept': 'application/vnd.github.v3+json'}
    
    try:
        url = f"https://api.github.com/gists/public?per_page=30&since={(datetime.now() - timedelta(days=30)).isoformat()}"
        resp = requests.get(url, headers=headers, timeout=10)
        
        if resp.status_code == 200:
            gists = resp.json()
            for gist in gists:
                for fname, file_info in gist.get('files', {}).items():
                    if any(fname.endswith(ext) for ext in ['.py', '.env', '.txt', '.json']):
                        raw_url = file_info.get('raw_url', '')
                        if raw_url:
                            raw_resp = requests.get(raw_url, timeout=8)
                            if raw_resp.status_code == 200:
                                tokens = extract_tokens(raw_resp.text)
                                for token in tokens:
                                    results.append({
                                        'token': token,
                                        'repo': f"Gist: {gist.get('id', '')}",
                                        'repo_url': gist.get('html_url', ''),
                                        'file': fname,
                                        'source': 'GitHub Gist'
                                    })
        
        time.sleep(0.3)
    except:
        pass
    
    return results[:max_results]

