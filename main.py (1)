def search_github(query, max_results=50):
    """GitHub Code Search API দিয়ে পাওয়ারফুল সার্চ"""
    results = []
    headers = {
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'Mozilla/5.0'
    }
    
    # একাধিক কিওয়ার্ড দিয়ে সার্চ
    search_queries = [
        f"{query} language:python",
        f"{query} language:javascript",
        f"{query} language:java",
        f"{query} language:go",
        f"{query} .env",
        f"{query} .txt",
        f"{query} extension:yml",
        f"{query} extension:yaml",
        f"{query} extension:json",
        f"{query} filename:config",
        f"{query} filename:.env",
        f"{query} filename:secret",
    ]
    
    for sq in search_queries[:5]:  # প্রথম ৫টা কোয়েরি
        try:
            url = f"https://api.github.com/search/code?q={requests.utils.quote(sq)}&per_page=30"
            resp = requests.get(url, headers=headers, timeout=10)
            
            if resp.status_code == 200:
                data = resp.json()
                for item in data.get('items', []):
                    repo = item['repository']
                    results.append({
                        'repo': repo['full_name'],
                        'repo_url': repo['html_url'],
                        'file': item['path'],
                        'file_url': item['html_url'],
                        'score': item.get('score', 0)
                    })
                    
                    if len(results) >= max_results * 2:
                        break
            
            time.sleep(0.3)  # রেট লিমিট
            
        except:
            continue
    
    return results[:max_results]

