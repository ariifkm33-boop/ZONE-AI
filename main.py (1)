def retest_all(uid):
    bot.send_message(uid, "⏳ *সব বট রি-টেস্ট করা হচ্ছে...*\n\nএটি কিছু সময় নিতে পারে...")
    
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT * FROM found_tokens")
    bots = c.fetchall()
    conn.close()
    
    active = 0
    inactive = 0
    
    for b in bots:
        bot_info = test_token(b['token'])
        
        conn = get_db()
        c = conn.cursor()
        
        if bot_info:
            c.execute("""UPDATE found_tokens SET is_active=1, bot_username=?, bot_name=?, bot_id=?,
                        can_join_groups=?, can_read_all=?, supports_inline=?, has_commands=?, last_checked=?, status=?
                        WHERE id=?""",
                     (bot_info['username'], bot_info['name'], bot_info['id'],
                      bot_info['can_join_groups'], bot_info['can_read_all'], bot_info['supports_inline'],
                      bot_info['has_commands'], datetime.now().isoformat(), 'Active', b['id']))
            active += 1
        else:
            c.execute("UPDATE found_tokens SET is_active=0, last_checked=?, status='Inactive' WHERE id=?",
                     (datetime.now().isoformat(), b['id']))
            inactive += 1
        
        conn.commit()
        conn.close()
    
    bot.send_message(uid,
        f"✅ *রি-টেস্ট সম্পন্ন!*\n\n"
        f"✅ Active: {active}\n"
        f"❌ Inactive: {inactive}\n"
        f"📊 মোট: {active + inactive}")

