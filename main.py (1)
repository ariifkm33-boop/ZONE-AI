@bot.callback_query_handler(func=lambda c: True)
def callback(call):
    try:
        uid = call.from_user.id
        mid = call.message.message_id
        cid = call.message.chat.id
        data = call.data
        
        if data == "show_all":
            show_found_bots(uid)
            bot.delete_message(cid, mid)
        
        elif data.startswith("info_"):
            bot_id = int(data.split('_')[1])
            conn = get_db()
            c = conn.cursor()
            c.execute("SELECT * FROM found_tokens WHERE id=?", (bot_id,))
            b = c.fetchone()
            conn.close()
            
            if b:
                status_emoji = "✅ চালু" if b['is_active'] else "❌ বন্ধ"
                features = []
                if b['has_commands']: features.append("📝 কমান্ড")
                if b['can_join_groups']: features.append("👥 গ্রুপ")
                if b['supports_inline']: features.append("💬 ইনলাইন")
                features_str = ', '.join(features) if features else 'কোনো তথ্য নেই'
                
                kb = types.InlineKeyboardMarkup()
                kb.add(types.InlineKeyboardButton("🔄 রি-টেস্ট", callback_data=f"retest_{b['id']}"))
                if b['repo_url']:
                    kb.add(types.InlineKeyboardButton("🌐 সোর্স দেখুন", url=b['repo_url']))
                
                txt = (
                    f"🤖 *বট ডিটেইলস*\n\n"
                    f"📛 নাম: `{b['bot_name']}`\n"
                    f"🆔 ইউজারনেম: @{b['bot_username']}\n"
                    f"🆔 আইডি: `{b['bot_id']}`\n"
                    f"🔑 টোকেন: `{b['token'][:10]}...{b['token'][-5:]}`\n"
                    f"📊 স্ট্যাটাস: {status_emoji}\n"
                    f"📁 সোর্স: {b['source']}\n"
                    f"📂 রিপো: `{b['repo_name'][:30]}`\n"
                    f"📄 ফাইল: {b['file_name']}\n"
                    f"⚙️ ফিচার: {features_str}\n"
                    f"📅 পাওয়া: {b['found_date'][:19]}"
                )
                
                bot.edit_message_text(txt, cid, mid, reply_markup=kb)
        
        elif data.startswith("retest_"):
            bot_id = int(data.split('_')[1])
            conn = get_db()
            c = conn.cursor()
            c.execute("SELECT * FROM found_tokens WHERE id=?", (bot_id,))
            b = c.fetchone()
            conn.close()
            
            if b:
                bot_info = test_token(b['token'])
                
                conn = get_db()
                c = conn.cursor()
                
                if bot_info:
                    c.execute("""UPDATE found_tokens SET is_active=1, bot_username=?, bot_name=?, bot_id=?,
                                can_join_groups=?, can_read_all=?, supports_inline=?, has_commands=?, last_checked=?, status=?
                                WHERE id=?""",
                             (bot_info['username'], bot_info['name'], bot_info['id'],
                              bot_info['can_join_groups'], bot_info['can_read_all'], bot_info['supports_inline'],
                              bot_info['has_commands'], datetime.now().isoformat(), 'Active', bot_id))
                    bot.answer_callback_query(call.id, f"✅ @{bot_info['username']} চালু আছে!")
                    txt = f"✅ *বট চালু আছে!*\n\n🤖 @{bot_info['username']}\n📛 {bot_info['name']}"
                else:
                    c.execute("UPDATE found_tokens SET is_active=0, last_checked=?, status='Inactive' WHERE id=?",
                             (datetime.now().isoformat(), bot_id))
                    bot.answer_callback_query(call.id, "❌ বট বন্ধ!")
                    txt = f"❌ *বট বন্ধ!*\n\n🔑 `{b['token'][:10]}...`"
                
                conn.commit()
                conn.close()
                
                bot.edit_message_text(txt, cid, mid)
    
    except Exception as e:
        logger.error(f"Callback Error: {e}")
        try: bot.answer_callback_query(call.id, "⚠️ ত্রুটি!")
        except: pass

